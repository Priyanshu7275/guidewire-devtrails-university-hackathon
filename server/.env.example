# -----------------------------------------------------------------------
# GigInsure Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.
# -----------------------------------------------------------------------

# Server port. Express will listen on this port.
PORT=5000

# MongoDB connection string. For local dev use the localhost URI.
# For production (e.g. MongoDB Atlas), replace with the Atlas URI.
MONGODB_URI=mongodb://localhost:27017/giginsure

# JWT signing secret. Use a long, random string in production.
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# OpenWeatherMap API key.
# Sign up free at: https://openweathermap.org/api
# Used for current weather (rain, temperature) and Air Pollution (AQI).
OPENWEATHERMAP_API_KEY=your_owm_key_here

# NewsAPI key.
# Sign up free at: https://newsapi.org/
# Used to fetch local disruption news (floods, strikes, curfews).
NEWS_API_KEY=your_newsapi_key_here

# Razorpay test credentials.
# Sign up at: https://razorpay.com/  -- use the test dashboard keys.
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
